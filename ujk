int getPrecedence(char op) {
	//const char* cstr = str.op();
	switch (op) {
	case '+':
	case '-':
		return 1;
	case '*':
	case '/':
		return 2;
	case'^':
		return 3;
	default:
		return 0;
	}
}


template <class T>
struct Stack
{
	float resize_factor{ 1.5 };
	size_t  top{ 0 };
	size_t size{};
	T* stack = nullptr;
};


template <class T>
void init(Stack<T>& st, size_t size) {
	st.size = size;
	st.stack = new T[size];
	st.top = 0;

}

template <class T>

void clear(Stack<T>& st) {
	st.top = 0;
	delete[] st.stack;
	st.stack = nullptr;
	st.size = 0;
}

template <class T>

bool emty(Stack<T>& st) {
	return(st.top == 0);

}


template <class T>

T peek(Stack <T>& st) {

	return (st.stack[st.top- 1]);

}
template <class T>
void resize(Stack<T>& st, size_t len) {
	if (len == st.size) return;

	T *temp_arr = new T[len];
	for (int i{ 0 }; i < std::min(len, st.size); ++i) {
		temp_arr[i] = st.stack[i];
	}
	delete[] st.stack;
	st.stack = temp_arr;
	st.top = std::min(len, st.top);
}

template <class T>
void push(Stack<T>& st, T temp) {
	if (st.top >= st.size) resize(st,  st.size * st.resize_factor);
		st.stack[st.top++] = temp;

}


template <class T>

T pop(Stack <T>& st) {

	return (st.stack[--st.top]);

}

template <class T>
std::string Pol_str(std::string str, Stack<T>& suck) {
	std:: string temp;
	for (int i{ 0 }; i < str.size(); ++i) {
		if (std::isdigit(str[i])) temp += str[i];
		else{
			if (suck.top == 0|| suck.stack[suck.top-1][0] == '(') push(suck, str.substr(i, 1));
			if (str[i] == ')') {
				while (suck.stack[suck.top-1][0] != '(') {
					temp += pop(suck);
				}
				++i;
				pop(suck);
			}
			 if(getPrecedence(suck.stack[suck.top-1][0])< getPrecedence(str[i])) push(suck, str.substr(i, 1));
			 else {
				 temp += pop(suck);
				 push(suck, str.substr(i, 1));
			 }

		}
	}
	while (suck.top > 0) {
		temp += pop(suck);
	}
	return temp;
}

int main() {
	std::string str = "2*2+3*(4-2)^2";
	int* temp = new int[1];
	
	Stack<std::string> a;
	init(a, 4);
	std:: cout << Pol_str(str, a);

	return 0;
}
